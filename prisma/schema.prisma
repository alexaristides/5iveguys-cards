generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- NextAuth ----------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  points        Int       @default(0)
  totalEarned   Int       @default(0)
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  cards         UserCard[]
  packOpens     PackOpen[]
  youtubeSync   YoutubeSync[]
  pointsEvents  PointsEvent[]
  rankSnapshots RankSnapshot[]
  channelStats  UserChannelStats[]

  challengedBattles CardBattle[] @relation("ChallengerBattles")
  acceptedBattles   CardBattle[] @relation("AcceptorBattles")
  wonBattles        CardBattle[] @relation("WonBattles")
  forumPosts        ForumPost[]
  forumReplies      ForumReply[]
  forumLikes        ForumLike[]
  forumReplyLikes   ForumReplyLike[]
  videoWatches      VideoWatch[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Channels ----------

model Channel {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  youtubeChannelId String   @unique
  description      String?
  thumbnailUrl     String?
  isActive         Boolean  @default(true)
  rewardTags       String?  // comma-separated, e.g. "Trading Cards,Merch,Exclusive Content"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cards        Card[]
  youtubeSync  YoutubeSync[]
  videoMeta    VideoMeta[]
  pointsEvents PointsEvent[]
  packOpens    PackOpen[]
  userCards    UserCard[]
  userStats    UserChannelStats[]
  forumPosts   ForumPost[]
  videoWatches VideoWatch[]
}

enum Rarity {
  common
  rare
  epic
  legendary
}

model Card {
  id           String   @id @default(cuid())
  channelId    String
  channel      Channel  @relation(fields: [channelId], references: [id])
  legacyId     String?
  name         String
  kit          String?
  rarity       Rarity
  imageUrl     String
  backImageUrl String?
  attribute    String?
  description  String?
  createdAt    DateTime @default(now())

  @@index([channelId])
  @@index([legacyId])
}

model UserChannelStats {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId        String
  channel          Channel  @relation(fields: [channelId], references: [id])
  points           Int      @default(0)
  totalEarned      Int      @default(0)
  watchTimeSeconds Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, channelId])
}

// ---------- YouTube sync ----------

model YoutubeSync {
  id                 String    @id @default(cuid())
  userId             String
  channelId          String?
  youtubeChannelId   String?
  isSubscribed       Boolean   @default(false)
  likedVideoIds      String    @default("[]")
  earlyLikedVideoIds String    @default("[]")
  subscribedAt       DateTime?
  lastSynced         DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel? @relation(fields: [channelId], references: [id])

  @@unique([userId, channelId])
}

// Publish dates for channel videos
model VideoMeta {
  id           String   @id @default(cuid())
  videoId      String
  channelId    String?
  publishedAt  DateTime
  title        String?
  thumbnailUrl String?

  channel Channel? @relation(fields: [channelId], references: [id])

  @@unique([videoId, channelId])
  @@index([channelId])
}

model VideoWatch {
  id             String   @id @default(cuid())
  userId         String
  videoId        String
  channelId      String
  secondsAwarded Int      @default(0)
  watchedAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id])

  @@unique([userId, videoId])
  @@index([userId, channelId])
}

// ---------- Cards & packs ----------

model UserCard {
  id         String   @id @default(cuid())
  userId     String
  channelId  String?
  cardId     String
  obtainedAt DateTime @default(now())
  isFavorite Boolean  @default(false)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel? @relation(fields: [channelId], references: [id])

  @@index([userId, channelId])
  @@index([userId, cardId])
}

model PackOpen {
  id        String   @id @default(cuid())
  userId    String
  channelId String?
  packType  String
  cardIds   String
  pointCost Int
  openedAt  DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel? @relation(fields: [channelId], references: [id])
}

// ---------- Points & leaderboard ----------

model PointsEvent {
  id         String   @id @default(cuid())
  userId     String
  channelId  String?
  type       String
  points     Int
  videoCount Int      @default(0)
  earnedAt   DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel? @relation(fields: [channelId], references: [id])

  @@index([userId, earnedAt])
  @@index([earnedAt])
  @@index([channelId, earnedAt])
}

model RankSnapshot {
  id          String   @id @default(cuid())
  userId      String
  channelId   String?
  rank        Int
  totalEarned Int
  snapshotAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([snapshotAt])
  @@index([userId, snapshotAt])
  @@index([channelId, snapshotAt])
}

// ---------- Battles ----------

enum BattleStatus {
  PENDING
  RESOLVED
  CANCELLED
}

model CardBattle {
  id                String       @id @default(cuid())
  challengerId      String
  challenger        User         @relation("ChallengerBattles", fields: [challengerId], references: [id])
  acceptorId        String?
  acceptor          User?        @relation("AcceptorBattles", fields: [acceptorId], references: [id])
  challengerCardIds String[]
  acceptorCardIds   String[]
  wager             Int
  status            BattleStatus @default(PENDING)
  winnerId          String?
  winner            User?        @relation("WonBattles", fields: [winnerId], references: [id])
  matchResults      Json?
  createdAt         DateTime     @default(now())
  resolvedAt        DateTime?

  @@index([status, createdAt])
  @@index([challengerId])
  @@index([acceptorId])
}

// ---------- Forum ----------

model ForumPost {
  id        String       @id @default(cuid())
  channelId String
  channel   Channel      @relation(fields: [channelId], references: [id])
  authorId  String
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title     String
  body      String
  isPinned  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  replies   ForumReply[]
  likes     ForumLike[]

  @@index([channelId, createdAt(sort: Desc)])
}

model ForumReply {
  id        String           @id @default(cuid())
  postId    String
  post      ForumPost        @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime         @default(now())

  parentId  String?
  parent    ForumReply?      @relation("ReplyThread", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  ForumReply[]     @relation("ReplyThread")

  likes     ForumReplyLike[]

  @@index([postId, createdAt])
  @@index([parentId])
}

model ForumReplyLike {
  id        String     @id @default(cuid())
  replyId   String
  reply     ForumReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([replyId, userId])
  @@index([replyId])
}

model ForumLike {
  id        String    @id @default(cuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([postId, userId])
  @@index([postId])
}
