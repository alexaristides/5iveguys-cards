generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  points        Int       @default(0)
  totalEarned   Int       @default(0)
  createdAt     DateTime  @default(now())

  accounts   Account[]
  sessions   Session[]
  cards      UserCard[]
  packOpens  PackOpen[]
  youtubeSync YoutubeSync?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model YoutubeSync {
  id                String   @id @default(cuid())
  userId            String   @unique
  youtubeChannelId  String?
  isSubscribed      Boolean  @default(false)
  likedVideoIds     String   @default("[]")
  commentCount      Int      @default(0)
  lastSynced        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Stores comment counts per YouTube channel author — built by the admin scan
model ChannelCommentCache {
  authorChannelId String   @id
  commentCount    Int      @default(0)
  updatedAt       DateTime @updatedAt
}

// Tracks when the last full channel comment scan ran
model ChannelScanStatus {
  id           String   @id @default("singleton")
  lastScanned  DateTime
  videoCount   Int      @default(0)
  commentCount Int      @default(0)
}

model UserCard {
  id         String   @id @default(cuid())
  userId     String
  cardId     String
  obtainedAt DateTime @default(now())
  isFavorite Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, cardId])
}

model PackOpen {
  id        String   @id @default(cuid())
  userId    String
  packType  String
  cardIds   String
  pointCost Int
  openedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
