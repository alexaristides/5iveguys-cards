# Copy this file to .env.local and fill in the values

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Google OAuth (with YouTube scopes)
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# YouTube channel to track
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxx

# Database (SQLite by default, change for production)
DATABASE_URL="file:./dev.db"

# Google site verification (get token from Google Search Console → HTML tag method)
GOOGLE_SITE_VERIFICATION=your-verification-token
